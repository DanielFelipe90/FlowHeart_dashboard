{
  "name": "Flutter Admin Dashboard",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "jdkDistro": "ms"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "PKief.material-icon-theme",
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "aaron-bond.better-comments",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "dart.flutterSdkPath": "/home/vscode/flutter",
        "dart.sdkPath": "/home/vscode/flutter/bin/cache/dart-sdk",
        "dart.lineLength": 80,
        "dart.previewFlutterUiGuides": true,
        "dart.previewFlutterUiGuidesCustomTracking": true,
        "dart.debugExternalPackageLibraries": false,
        "dart.debugSdkLibraries": false,
        "dart.completeFunctionCalls": true,
        "dart.enableSdkFormatter": true,

        "workbench.iconTheme": "material-icon-theme",
        "material-icon-theme.activeIconPack": "flutter",

        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.rulers": [80],
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": "active",
        "editor.inlayHints.enabled": "on",
        "editor.quickSuggestionsDelay": 0,

        "[dart]": {
          "editor.formatOnSave": true,
          "editor.formatOnType": true,
          "editor.selectionHighlight": false,
          "editor.suggest.snippetsPreventQuickSuggestions": false,
          "editor.suggestSelection": "first",
          "editor.tabCompletion": "onlySnippets",
          "editor.wordBasedSuggestions": "off",
          "editor.defaultFormatter": "Dart-Code.dart-code"
        },

        "files.exclude": {
          "**/.dart_tool": true,
          "**/.flutter-plugins": true,
          "**/.flutter-plugins-dependencies": true,
          "**/build": true
        },

        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "JAVA_HOME": "/usr/lib/jvm/msopenjdk-17-amd64",
          "FLUTTER_ROOT": "/home/vscode/flutter",
          "ANDROID_SDK_ROOT": "/home/vscode/android-sdk",
          "PATH": "/home/vscode/flutter/bin:/home/vscode/android-sdk/cmdline-tools/latest/bin:/home/vscode/android-sdk/platform-tools:${env:PATH}"
        },

        "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
        "errorLens.gutterIconsEnabled": true
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "vscode"
}
